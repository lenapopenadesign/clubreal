---
import Layout from '../layouts/Layout.astro';
import { Building2, HardHat, ClipboardList, House, Users, MessageSquare, TrendingUp, Calendar, Heart, HeartHandshake, ShieldCheck } from 'lucide-react';
import page from '../../content/pages/warum.json';

const iconMap: Record<string, any> = {
  clipboardList: ClipboardList, building2: Building2, house: House, hardHat: HardHat,
  users: Users, messageSquare: MessageSquare, trendingUp: TrendingUp, calendar: Calendar,
  heart: Heart, heartHandshake: HeartHandshake, shieldCheck: ShieldCheck,
};
---
<Layout
  title="Unser Angebot – Club Real Immobiliensachverständige"
  description="Entdecken Sie die Vorteile einer Mitgliedschaft beim Club Real: exklusives Netzwerk, Fachveranstaltungen und Weiterbildung für Immobilien-Sachverständige in Österreich."
>
  <section
    class="flex flex-col items-center justify-center gap-8 px-6 md:px-[120px] py-16 md:py-20 bg-cover bg-center"
    style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/flagged/photo-1556010856-6d1801f17ac8?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixlib=rb-4.1.0&q=80&w=1080')"
  >
    <div class="inline-flex px-4 py-1.5 border border-white/20 bg-white/10">
      <span class="text-xs font-medium font-[family-name:var(--font-heading)] text-white/80 tracking-wider">{page.heroBadge}</span>
    </div>
    <h1 class="text-3xl md:text-[52px] font-semibold font-[family-name:var(--font-heading)] text-white text-center tracking-tight">{page.heroHeading}</h1>
    <p class="text-lg text-white/75 text-center leading-relaxed max-w-[700px]">{page.heroSubtext}</p>
  </section>

  <section class="bg-card px-6 md:px-[120px] py-16 md:py-20">
    <div class="flex flex-col items-center gap-3 mb-12">
      <span class="text-xs font-medium font-[family-name:var(--font-heading)] text-primary tracking-widest">{page.benefitsLabel}</span>
      <h2 class="text-4xl font-semibold font-[family-name:var(--font-heading)] text-foreground text-center tracking-tight">{page.benefitsHeading}</h2>
    </div>
    <div class="flex flex-col gap-5">
      <div class="grid grid-cols-1 md:grid-cols-6 gap-5">
        {page.benefits.slice(0, 3).map((benefit) => {
          const Icon = iconMap[benefit.icon];
          return (
            <div class="flex flex-col gap-4 p-7 bg-white shadow-sm md:col-span-2">
              {Icon && <Icon className="w-6 h-6 text-primary" />}
              <h3 class="text-lg font-semibold font-[family-name:var(--font-heading)] text-foreground">{benefit.title}</h3>
              <p class="text-sm text-muted leading-relaxed">{benefit.description}</p>
            </div>
          );
        })}
      </div>
      <div class="grid grid-cols-1 md:grid-cols-6 gap-5">
        {page.benefits.slice(3).map((benefit, i) => {
          const Icon = iconMap[benefit.icon];
          return (
            <div class={`flex flex-col gap-4 p-7 bg-white shadow-sm md:col-span-2 ${i === 0 ? 'md:col-start-2' : ''}`}>
              {Icon && <Icon className="w-6 h-6 text-primary" />}
              <h3 class="text-lg font-semibold font-[family-name:var(--font-heading)] text-foreground">{benefit.title}</h3>
              <p class="text-sm text-muted leading-relaxed">{benefit.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="flex flex-col items-center justify-center gap-8 bg-dark px-6 md:px-[120px] py-16 md:py-20">
    <span class="text-xs font-medium font-[family-name:var(--font-heading)] text-primary tracking-widest">{page.ctaLabel}</span>
    <h2 class="text-2xl md:text-[40px] font-semibold font-[family-name:var(--font-heading)] text-white text-center leading-snug tracking-tight max-w-[700px] whitespace-pre-line">{page.ctaHeading}</h2>
    <p class="text-base text-white/75 text-center leading-relaxed max-w-[550px]">{page.ctaBody}</p>
    <a href="mailto:willkommen@clubreal.at" class="inline-flex items-center justify-center gap-1.5 rounded-full bg-primary text-white px-6 py-3 h-12 text-sm font-medium font-[family-name:var(--font-heading)]">
      {page.ctaButtonLabel}
    </a>
  </section>
</Layout>
