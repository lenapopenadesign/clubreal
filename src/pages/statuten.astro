---
import Layout from '../layouts/Layout.astro';
import page from '../../content/pages/statuten.json';
---
<Layout
  title="Vereinsstatuten – Club Real Immobiliensachverständige"
  description="Die Statuten des Club Real Immobiliensachverständige, beschlossen in der Generalversammlung am 11. März 2025."
>
  <section class="bg-background px-6 md:px-20 py-20">
    <h1 class="text-5xl font-semibold font-[family-name:var(--font-heading)] text-foreground tracking-tight leading-tight mb-6">{page.heroHeading}</h1>
    <p class="text-lg text-muted leading-relaxed max-w-[700px] whitespace-pre-line">{page.heroSubtext}</p>
    {page.pdfUrl && (
      <a href={page.pdfUrl} target="_blank" class="inline-flex items-center justify-center gap-1.5 rounded-full bg-primary text-white px-6 py-3 h-12 text-sm font-medium font-[family-name:var(--font-heading)] mt-6">
        {page.pdfButtonLabel}
      </a>
    )}
  </section>
  <section class="bg-card px-6 md:px-20 py-16">
    <div class="max-w-[800px] flex flex-col gap-12">
      {page.sections.map((section) => (
        <article class="flex flex-col gap-4">
          <h2 class="text-xl font-semibold font-[family-name:var(--font-heading)] text-foreground">{section.heading}</h2>
          {section.body.split('\n').filter(Boolean).map((line) => (
            <p class="text-base text-muted leading-relaxed">{line}</p>
          ))}
        </article>
      ))}
      {page.footerNote && <p class="text-sm text-muted italic">{page.footerNote}</p>}
    </div>
  </section>
</Layout>
