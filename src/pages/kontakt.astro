---
import Layout from '../layouts/Layout.astro';
import KontaktForm from '../components/KontaktForm.tsx';
import page from '../../content/pages/kontakt.json';
---
<Layout
  title="Mitglied werden – Club Real Immobiliensachverständige"
  description="Werden Sie Teil des Club Real – dem Netzwerk qualifizierter Immobilien-Sachverständiger in Österreich. Jetzt Kontakt aufnehmen und Mitglied werden."
>
  <section class="bg-background px-6 md:px-20 py-20">
    <h1 class="text-5xl font-semibold font-[family-name:var(--font-heading)] text-foreground tracking-tight leading-tight mb-6">{page.heroHeading}</h1>
    <p class="text-lg text-muted leading-relaxed max-w-[700px]">{page.heroBody}</p>
  </section>
  <section class="bg-card px-6 md:px-20 py-16">
    <div class="max-w-[800px]">
      <KontaktForm client:load />
    </div>
  </section>
</Layout>
