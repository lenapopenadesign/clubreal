---
import Layout from '../layouts/Layout.astro';
import { ExternalLink, Scale, Linkedin, MapPin } from 'lucide-react';
import KeywordCloud from '../components/KeywordCloud.tsx';
import membersData from '../../content/members.json';

const members = membersData.members;

const linkLabel: Record<string, string> = {
  website: 'Website',
  justiz: 'SV Liste Justiz',
  linkedin: 'LinkedIn',
};
---
<Layout
  title="Mitgliederverzeichnis – Club Real Immobiliensachverständige"
  description="Alle Mitglieder des Club Real im Überblick – qualifizierte Immobilien-Sachverständige aus ganz Österreich mit Expertise in Bewertung, Maklerei und Hausverwaltung."
>
  <section class="bg-background px-6 md:px-20 py-20">
    <h1 class="text-5xl font-medium font-[family-name:var(--font-heading)] text-foreground tracking-tight mb-6">Mitgliederverzeichnis</h1>
    <p class="text-xl text-muted leading-normal max-w-[600px] mb-6">Ein Netzwerk ist nur so stark wie seine Mitglieder.</p>
    <p class="text-base text-muted leading-relaxed max-w-[700px]">Hier finden Sie Mitglieder des Club Real Immobiliensachverständige und ihre Kontaktmöglichkeiten.</p>
  </section>

  <section class="bg-card px-6 md:px-20 pt-10 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {members.map((member) => (
        <div class="flex flex-col gap-3 p-6 rounded-2xl bg-background border border-border">
          <h3 class="text-base font-medium">{member.name}</h3>
          <p class="text-[13px] text-muted font-medium">{member.role}</p>
          <p class="text-[13px] text-muted flex items-center gap-1">
            <MapPin className="w-3 h-3 shrink-0" />
            {member.location}
          </p>
          {member.links?.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-1">
              {member.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-full bg-secondary px-3 py-1.5 text-xs text-foreground hover:bg-secondary/70 transition-colors"
                >
                  {link.type === 'website' && <ExternalLink className="w-3.5 h-3.5 text-muted" />}
                  {link.type === 'justiz' && <Scale className="w-3.5 h-3.5 text-muted" />}
                  {link.type === 'linkedin' && <Linkedin className="w-3.5 h-3.5 text-muted" />}
                  {linkLabel[link.type] ?? link.type}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
    <KeywordCloud client:load />
  </section>
</Layout>
