---
import Layout from '../layouts/Layout.astro';
import { Building2, HardHat, ClipboardList, House, Users, MessageSquare, TrendingUp, Calendar, Heart, HeartHandshake, ShieldCheck } from 'lucide-react';
import page from '../../content/pages/home.json';

const iconMap: Record<string, any> = {
  clipboardList: ClipboardList, building2: Building2, house: House, hardHat: HardHat,
  users: Users, messageSquare: MessageSquare, trendingUp: TrendingUp, calendar: Calendar,
  heart: Heart, heartHandshake: HeartHandshake, shieldCheck: ShieldCheck,
};
---
<Layout
  title="Club Real – Netzwerk für Immobilien-Sachverständige in Österreich"
  description="Club Real ist das Netzwerk qualifizierter Immobilien-Sachverständiger in Österreich. Fachkompetenz, kollegialer Austausch und höchste Qualitätsstandards in der Immobilienbewertung."
>
  <section
    class="relative flex flex-col items-center justify-center gap-8 px-6 md:px-[120px] py-16 md:py-[100px] bg-cover bg-center"
    style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/background_landingpage.png')"
  >
    <h1 class="text-3xl md:text-[52px] font-semibold font-[family-name:var(--font-heading)] text-white text-center leading-tight tracking-tight max-w-[900px]">
      {page.heroHeading}
    </h1>
    <p class="text-lg text-white/75 text-center leading-relaxed max-w-[700px] font-[family-name:var(--font-body)]">
      {page.heroSubtext}
    </p>
    <a href="/warum-club-real" class="inline-flex items-center justify-center gap-1.5 rounded-full bg-primary text-white px-6 py-3 h-12 text-sm font-medium font-[family-name:var(--font-heading)]">
      {page.heroCta}
    </a>
  </section>

  <section class="bg-card px-6 md:px-[120px] py-16 md:py-20">
    <div class="flex flex-col items-center gap-3 mb-12">
      <span class="text-xs font-medium font-[family-name:var(--font-heading)] text-primary tracking-widest">{page.featuresLabel}</span>
      <h2 class="text-4xl font-semibold font-[family-name:var(--font-heading)] text-foreground text-center tracking-tight">{page.featuresHeading}</h2>
      <p class="text-base text-muted text-center leading-relaxed max-w-[670px]">{page.featuresSubtext}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      {page.features.map((feature) => {
        const Icon = iconMap[feature.icon];
        return (
          <div class="flex flex-col gap-4 p-7 bg-white shadow-sm">
            {Icon && <Icon className="w-6 h-6 text-primary" />}
            <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] text-foreground">{feature.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{feature.description}</p>
          </div>
        );
      })}
    </div>
  </section>

  <section class="flex flex-col md:flex-row items-center gap-10 md:gap-16 bg-dark px-6 md:px-[120px] py-16 md:py-20">
    <div class="w-full md:w-1/2 h-[250px] md:h-[400px] bg-cover bg-center" style="background-image: url('/Team.png')" />
    <div class="w-full md:w-1/2 flex flex-col gap-6">
      <span class="text-xs font-medium font-[family-name:var(--font-heading)] text-primary tracking-widest">{page.missionLabel}</span>
      <h2 class="text-[32px] font-semibold font-[family-name:var(--font-heading)] text-white leading-snug tracking-tight">{page.missionHeading}</h2>
      <p class="text-base text-white/75 leading-relaxed">{page.missionBody}</p>
      <div class="w-12 h-0.5 bg-primary" />
      <p class="text-sm text-white/60 italic font-medium">{page.missionQuote}</p>
    </div>
  </section>
</Layout>
