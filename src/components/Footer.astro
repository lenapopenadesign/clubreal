---
---
<footer class="bg-card border-t border-border px-6 md:px-[120px] py-12 md:py-16">
  <div class="flex flex-col md:flex-row md:justify-between gap-10 mb-12">
    <div class="flex flex-col gap-4 md:w-[400px]">
      <img src="/logo.png" alt="Club Real" class="h-9 w-[140px] object-contain" />
      <p class="text-sm text-muted leading-relaxed max-w-[350px]">
        Klar in der Sache. Kollegial im Austausch.<br />
        Professionell im Anspruch.
      </p>
    </div>

    <div class="grid grid-cols-2 md:flex gap-8 md:gap-16">
      <div class="flex flex-col gap-3">
        <h4 class="text-xs font-semibold font-[family-name:var(--font-heading)] tracking-wider text-foreground">
          Navigation
        </h4>
        <a href="/warum-club-real" class="text-sm text-muted hover:text-foreground">Unser Angebot</a>
        <a href="/mitglieder" class="text-sm text-muted hover:text-foreground">Mitglieder</a>
        <a href="/crsv" class="text-sm text-muted hover:text-foreground">CRSV</a>
      </div>
      <div class="flex flex-col gap-3">
        <h4 class="text-xs font-semibold font-[family-name:var(--font-heading)] tracking-wider text-foreground">
          Rechtliches
        </h4>
        <a href="/statuten" class="text-sm text-muted hover:text-foreground">Statuten</a>
        <a href="/datenschutz" class="text-sm text-muted hover:text-foreground">Datenschutz</a>
        <a href="/impressum" class="text-sm text-muted hover:text-foreground">Impressum</a>
      </div>
      <div class="flex flex-col gap-3 col-span-2 md:col-span-1">
        <h4 class="text-xs font-semibold font-[family-name:var(--font-heading)] tracking-wider text-foreground">
          Kontakt
        </h4>
        <a href="mailto:willkommen@clubreal.at" class="text-sm text-muted hover:text-foreground">
          willkommen@clubreal.at
        </a>
        <span class="text-sm text-muted">Wien, Österreich</span>
      </div>
    </div>
  </div>

  <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 pt-6 border-t border-border">
    <span class="text-xs text-muted">© 2026 Club Real. Alle Rechte vorbehalten.</span>
  </div>
</footer>
